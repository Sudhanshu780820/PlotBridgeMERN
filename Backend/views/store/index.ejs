<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<body class="bg-gray-100 min-h-screen">
  

  <main class="max-w-5xl mx-auto p-6 mt-16">
    <h2 class="text-2xl font-bold mb-2">Welcome to Airbnb Index Page</h2>
    <p class="text-amber-50 mb-6">Here are the list of homes:</p>

    <% if (registeredLand && registeredLand.length) { %>
      <ul class="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
        <% registeredLand.forEach(home => { %>

          <!-- CARD -->
          <li class="bg-white rounded-md shadow-sm w-64 mx-auto overflow-hidden">
  
  <img 
    src="<%= home.photo %>" 
    alt="<%= home.houseName %>" 
    class="w-full h-32 object-cover"
  >

  <div class="p-3">
    <div class="flex justify-between items-center">
      <h3 class="text-sm font-semibold truncate">
        <%= home.houseName %>
      </h3>
      <span class="text-red-600 font-bold text-sm">
        ₹<%= home.price %>
      </span>
    </div>

    <p class="text-xs text-gray-500 mt-1">
      <%= home.location %>
    </p>

    <div class="mt-1 flex items-center text-xs text-gray-600">
      <% const rating = parseFloat(home.rating) || 0; %>
      <span class="mr-1"><%= rating.toFixed(1) %></span>
      <span>
        <% for (let i = 0; i < 5; i++) { %>
          <%= i < Math.round(rating) ? '★' : '☆' %>
        <% } %>
      </span>
    </div>

    <div class="mt-3 flex gap-2">
        <a href="/homes/<%= home._id %>" 
     class="flex-1 text-center border border-red-500 text-red-500 py-1 rounded text-xs block w-full text-center bg-gradient-to-r from-rose-500 to-pink-600 text-white py-3 rounded-lg font-semibold text-lg hover:shadow-lg ">
    Details
  </a>

      <a href="/book/<%= encodeURIComponent(home.houseName) %>"
         class="flex-1 text-center border border-red-500 text-red-500 py-1 rounded text-xs block w-full text-center bg-gradient-to-r from-rose-500 to-pink-600 text-white py-3 rounded-lg font-semibold text-lg hover:shadow-lg ">
        Book
      </a>
    </div>
  </div>
</li>


        <% }) %>
      </ul>
    <% } %>
  </main>
</body>
</html>
