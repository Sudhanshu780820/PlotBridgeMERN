<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<body class="bg-slate-50 font-sans antialiased">

    <!-- Hero Search Banner Section -->
    <section class="bg-emerald-900 py-20 px-4 text-center pt-32">
        <h2 class="text-white text-4xl md:text-6xl font-bold mb-6">Own a piece of the Earth.</h2>
        <p class="text-emerald-100 text-lg mb-10 max-w-xl mx-auto">
            The most trusted platform for buying and selling residential and agricultural land in Madhya Pradesh.
        </p>
        
        <!-- Search Bar Form Component -->
        <div class="max-w-2xl mx-auto">
            <form action="/search" method="GET" class="bg-white p-2 rounded-2xl shadow-xl flex flex-col md:flex-row gap-2">
                 <input type="hidden" name="source" value="mainpage">
                <input 
                    type="text" 
                    name="search" 
                    placeholder="Search by city (e.g. Bhopal, Indore...)" 
                    class="flex-grow p-4 outline-none rounded-xl text-slate-800"
                    required
                >
                <button type="submit" class="bg-orange-500 text-white px-8 py-4 rounded-xl font-bold hover:bg-orange-600 transition duration-200">
                    Search
                </button>
            </form>
        </div>
    </section>

    <!-- Main Featured Plots Container -->
    <main class="container mx-auto px-4 py-12 max-w-7xl">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-2xl font-bold text-slate-800">Featured Plots</h3>
            <a href="/browse" class="text-emerald-600 font-semibold hover:underline text-sm">See all &rarr;</a>
        </div>

        <!-- Compact 4-Column Grid Architecture -->
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            <% if (registeredLand && registeredLand.length > 0) { %>
                <% registeredLand.forEach(plot => { %>
                    
                    <!-- Clickable Mini-Card Frame -->
                    <a href="/plot/<%= plot._id %>" class="group bg-white rounded-xl overflow-hidden shadow-sm border border-slate-100 hover:border-emerald-500 hover:shadow-md transition duration-200 flex flex-col text-xs">
                        
                        <!-- Image Container Frame -->
                        <div class="h-32 bg-slate-100 relative overflow-hidden shrink-0">
                            <% if (plot.photo && plot.photo.length > 0) { %>
                                <img src="<%= plot.photo[0] %>" alt="<%= plot.LandName %>" class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
                            <% } else { %>
                                <div class="w-full h-full flex items-center justify-center text-slate-300 font-bold">No Image</div>
                            <% } %>
                            
                            <!-- Dynamic Category Pill Label (Top Left) -->
                            <span class="absolute top-2 left-2 bg-white/95 backdrop-blur px-1.5 py-0.5 rounded text-[9px] font-black uppercase tracking-wider text-emerald-700 shadow-sm z-10">
                                <%= plot.category %>
                            </span>

                            <!-- Floating Edit Button Overlay (Top Right) -->
                            <% if (locals.currentUser && plot.host && plot.host.toString() === currentUser._id.toString()) { %>
                                <object type="unsupported/mime">
                                    <a href="/land/edit-land/<%= plot._id %>?editing=true" 
                                       onclick="event.stopPropagation();" 
                                       class="absolute top-2 right-2 bg-amber-500 hover:bg-amber-600 text-white p-1.5 rounded-lg shadow-md transition-colors duration-200 z-20 flex items-center justify-center" 
                                       title="Edit Listing"
                                    >
                                        <!-- Minimalist Pencil Vector Graphic -->
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
                                        </svg>
                                    </a>
                                </object>
                            <% } %>
                        </div>

                        <!-- Horizontal Layout Information Content Block -->
                        <div class="p-3 flex flex-col gap-2">
                            <!-- Title Frame -->
                            <h4 class="font-bold text-slate-800 text-sm leading-tight truncate" title="<%= plot.LandName %>">
                                <%= plot.LandName %>
                            </h4>
                            
                            <!-- Shared Row Layout: Price & Location Split Side-by-Side -->
                            <div class="grid grid-cols-2 gap-1.5">
                                <!-- Highlighted Price Box Component -->
                                <div class="bg-emerald-50 rounded-lg p-1.5 border border-emerald-100/50 flex flex-col justify-center">
                                    <span class="text-emerald-700 font-medium uppercase text-[8px] tracking-wider leading-none">Price</span>
                                    <p class="text-[13px] font-black text-emerald-600 leading-none mt-1 truncate">
                                        ₹<%= plot.price %><span class="text-[9px] font-bold uppercase ml-0.5"><%= plot.priceUnit %></span>
                                    </p>
                                </div>
                                
                                <!-- Highlighted Location Box Component -->
                                <div class="bg-slate-50 text-slate-700 rounded-lg p-1.5 border border-slate-100 flex items-center min-w-0">
                                    <svg class="w-3 h-3 mr-1 shrink-0 text-orange-500" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
                                    </svg>
                                    <span class="font-bold truncate text-[11px]"><%= plot.location %></span>
                                </div>
                            </div>
                            
                            <!-- Inline Land Area Dimension Footer Section -->
                            <div class="pt-1.5 border-t border-slate-100 text-slate-500 font-medium text-[10px] flex justify-between items-center">
                                <span>Area Size</span>
                                <span class="text-slate-800 font-bold"><%= plot.LandSize %> <%= plot.sizeUnit %></span>
                            </div>
                        </div>

                    </a>
                <% }) %>
            <% } else { %>
                <!-- Empty Grid State Condition Case -->
                <div class="col-span-full text-center py-12 bg-white rounded-2xl border border-slate-100 p-6">
                    <p class="text-slate-400 font-medium">No featured properties are currently listed.</p>
                </div>
            <% } %>
        </div>
    </main>

    <!-- Global Layout Footer Component -->
    <footer class="bg-slate-900 text-slate-400 py-12 mt-20">
        <div class="container mx-auto px-4 text-center">
            <p>&copy; 2026 PlotBridge Land Solutions. All rights reserved.</p>
        </div>
    </footer>

</body>
</html>