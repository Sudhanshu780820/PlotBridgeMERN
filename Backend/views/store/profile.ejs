<%- include('../partials/head') %>

<body class="bg-slate-50 font-sans antialiased">
  <%- include('../partials/nav') %>

  <!-- Main layout container with top spacing for the global navbar -->
  <main class="pt-28 pb-16 min-h-screen max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Grid Layout: Left sidebar for Quick View, Right panel for deep details -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- LEFT COLUMN: Profile Summary Card -->
      <div class="space-y-6">
        <div class="bg-white rounded-[2rem] p-6 shadow-xl shadow-slate-100 border border-slate-100 text-center">
          
          <!-- Profile Image with Cloudinary fallback -->
          <div class="relative w-32 h-32 mx-auto mb-4">
            <img src="<%= user.profilePhoto || '/images/default-avatar.png' %>" 
                 alt="Profile Picture" 
                 class="w-full h-full object-cover rounded-full ring-4 ring-emerald-500/20 shadow-md">
            
            <% if (user.isEmailVerified && user.isPhoneVerified) { %>
              <span class="absolute bottom-1 right-1 bg-emerald-500 text-white p-1.5 rounded-full shadow border-2 border-white flex items-center justify-center" title="Verified Account">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
              </span>
            <% } %>
          </div>

          <h2 class="text-xl font-bold text-slate-800"><%= user.firstName %> <%= user.lastName || '' %></h2>
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mt-1">PlotBridge Member</p>
          
          <!-- Real-time Verification Badge Indicators -->
          <div class="mt-4 flex flex-wrap justify-center gap-2">
            <!-- Email Badge -->
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold <%= user.isEmailVerified ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' : 'bg-amber-50 text-amber-700 border border-amber-200' %>">
              <span class="w-1.5 h-1.5 rounded-full <%= user.isEmailVerified ? 'bg-emerald-500' : 'bg-amber-500' %>"></span>
              Email <%= user.isEmailVerified ? 'Verified' : 'Pending' %>
            </span>

            <!-- Phone Badge -->
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold <%= user.isPhoneVerified ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' : 'bg-amber-50 text-amber-700 border border-amber-200' %>">
              <span class="w-1.5 h-1.5 rounded-full <%= user.isPhoneVerified ? 'bg-emerald-500' : 'bg-amber-500' %>"></span>
              Phone <%= user.isPhoneVerified ? 'Verified' : 'Pending' %>
            </span>
          </div>

          <hr class="my-6 border-slate-100">

          <!-- Mini platform activity stats -->
          <div class="grid grid-cols-2 gap-4 text-left">
            <div class="bg-slate-50 p-3 rounded-xl text-center">
              <span class="block text-xs font-bold text-slate-400 uppercase tracking-wide">My Plots</span>
              <span class="text-lg font-black text-slate-700"><%= user.myPlotsCount || 0 %></span>
            </div>
            <div class="bg-slate-50 p-3 rounded-xl text-center">
              <span class="block text-xs font-bold text-slate-400 uppercase tracking-wide">Inquiries</span>
              <span class="text-lg font-black text-slate-700"><%= user.inquiriesCount || 0 %></span>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT COLUMN: Detailed Information Tabs & Data Forms -->
      <div class="lg:col-span-2 space-y-6">
        
        <!-- Account Details Card -->
        <div class="bg-white rounded-[2rem] p-8 shadow-xl shadow-slate-100 border border-slate-100">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-lg font-bold text-slate-800 flex items-center gap-2">
              <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
              Account Credentials & Info
            </h3>
            <button class="text-xs font-bold text-emerald-600 hover:text-emerald-700 bg-emerald-50 px-3 py-1.5 rounded-lg transition-all">Edit Profile</button>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <span class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">First Name</span>
              <div class="bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm font-medium text-slate-700">
                <%= user.firstName %>
              </div>
            </div>

            <div>
              <span class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Last Name</span>
              <div class="bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm font-medium text-slate-700">
                <%= user.lastName || '—' %>
              </div>
            </div>

            <div>
              <span class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Email Address</span>
              <div class="bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm font-medium text-slate-700 flex items-center justify-between">
                <span><%= user.email %></span>
                <% if (user.isEmailVerified) { %>
                  <svg class="w-4 h-4 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                <% } %>
              </div>
            </div>

            <div>
              <span class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Phone Number</span>
              <div class="bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm font-medium text-slate-700 flex items-center justify-between">
                <span>+91 <%= user.phone %></span>
                <% if (user.isPhoneVerified) { %>
                  <svg class="w-4 h-4 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                <% } %>
              </div>
            </div>
          </div>
        </div>

        <!-- Identity & Legal Compliance Status -->
        <div class="bg-white rounded-[2rem] p-8 shadow-xl shadow-slate-100 border border-slate-100">
          <h3 class="text-lg font-bold text-slate-800 flex items-center gap-2 mb-6">
            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            KYC & Document Verification
          </h3>

          <div class="bg-slate-50 rounded-2xl p-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <div class="flex items-center gap-3">
              <div class="p-3 bg-white rounded-xl shadow-sm text-slate-400">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2v-3M10 6a2 2 0 012-2h2a2 2 0 012 2m-6 0v4m0 0h6m-6 0a2 2 0 002 2h2a2 2 0 002-2V6a2 2 0 00-2-2h-2a2 2 0 00-2 2z"></path></svg>
              </div>
              <div>
                <h4 class="text-sm font-bold text-slate-700">Aadhaar Card Copy</h4>
                <p class="text-xs text-slate-400 font-medium">Uploaded encrypted verification document</p>
              </div>
            </div>

            <!-- Action to View Document safely on Cloudinary -->
            <a href="<%= user.aadhaarCard %>" target="_blank" 
               class="inline-flex items-center gap-1 text-xs font-bold text-emerald-600 hover:text-emerald-700 bg-white shadow-sm border border-slate-100 px-4 py-2 rounded-xl transition-all">
              View File
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
            </a>
          </div>

          <!-- Safe platform info callout -->
          <div class="mt-4 border border-emerald-100 bg-emerald-50/50 rounded-xl px-4 py-3 flex gap-2">
            <svg class="w-4 h-4 text-emerald-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <p class="text-[11px] text-emerald-800 leading-normal font-medium">
              Your Aadhaar document data is encrypted safely via Cloudinary servers and remains strictly confidential. It is only reviewed manually by managers to clear listing authorization.
            </p>
          </div>
        </div>

      </div>
    </div>
  </main>
</body>
</html>