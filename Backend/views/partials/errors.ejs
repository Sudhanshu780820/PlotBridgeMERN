<% if (typeof errorMessages !== 'undefined' && errorMessages && errorMessages.length > 0) { %>
  <div class="mb-6 overflow-hidden rounded-xl border border-red-200 bg-red-50 shadow-sm" role="alert">
    <div class="flex items-center gap-2 bg-red-600 px-4 py-2">
      <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h3 class="text-sm font-bold text-white">Please fix the following:</h3>
    </div>
    
    <div class="p-4">
      <ul class="space-y-1">
        <% errorMessages.forEach(function(message) { %>
          <li class="flex items-start text-sm text-red-700">
            <span class="mr-2 text-red-400">•</span>
            <%= message %>
          </li>
        <% }); %>
      </ul>
    </div>
  </div>
<% } %>